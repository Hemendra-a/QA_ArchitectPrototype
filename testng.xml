<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Testing Baba Parallel Suite" parallel="tests" thread-count="2" verbose="2">
	<listeners >
	<listener class-name="reporter.ExtentListeners"></listener></listeners>
    <!-- Chrome Tests -->
    <test name="Chrome Tests" parallel="classes" thread-count="2" enabled="true">
        <parameter name="browser" value="Chrome"/>
        <classes>
            <class name="test.Logintest"/>
            <class name="test.CheckBox_test"/>
        </classes>
    </test>

    <!-- Firefox Tests -->
    <test name="Firefox Tests" parallel="classes" thread-count="2" enabled="false">
        <parameter name="browser" value="Firefox"/>
        <classes>
            <class name="test.RadioButton_test"/>
            <class name="test.Frame_test"/>
        </classes>
    </test>

</suite>
